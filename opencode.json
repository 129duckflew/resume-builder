{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": "ask",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "model": {
    "compact": {
      "tail_turns": 20
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    },
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
